# GoalOS gitignore

# ─── 编译产物 ───
/goalos-daemon
/goalos
/goalos-cli
/plugin-shell
/plugin-websearch
*.exe

# ─── IDE ───
.idea/
.vscode/
*.swp
*.swo

# ─── OS ───
.DS_Store
Thumbs.db

# ─── 临时文件 ───
/tmp/
*.tmp
*.log

# ─── Go ───
vendor/

# ─── 测试产物 ───
*.test
*.out
coverage.txt

# ─── 用户数据 ───
~/.goalos/
~/Goals/

# ─── 内部文档（仅本地，不发布到 GitHub）───
发布规范.md
开发日志.md
验收规范.md
开发规范.md
测试规范.md
开发计划v1.1.0.md

# ─── 开发文档目录（完全本地，不在本仓库内）───
# 所有开发文档位于 ../开发文档/。不纳入版本控制

# ─── 密钥与本地配置 ───
.env
RELEASE.md
upload-release.sh

# ─── Plugin 二进制（CI 构建，不提交源码仓库）───
/plugins/capability/*/plugin-shell
/plugins/capability/*/plugin-websearch
daemon.test.yaml
