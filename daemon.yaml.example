# GoalOS 配置文件模板 — 复制为 ~/.goalos/config/daemon.yaml 后填入真实值
#
# 此文件可安全提交到 Git — 不含任何真实密钥。
# 本地测试用: 复制为 daemon.test.yaml 填入真实 API Key（.gitignore 已保护）

daemon:
  port: 18920
  autonomy_level: autonomous     # observe|suggest|approve|autonomous

llm:
  provider: openai               # openai|anthropic|ollama
  model: glm-5.1                 # 模型名。OpenRouter 格式: openai/gpt-4o
  api_key: ""                    # 填写 API Key。也支持环境变量 GOALOS_LLM_API_KEY
  base_url: ""                   # API 地址。空=默认端点
  max_tokens: 4096
  temperature: 0.3
  timeout: 300s

# 多模型验证（可选。用于代码审查时并行调用多个 LLM）
# multi_llm:
#   enabled: true
#   providers:
#     - name: primary
#       model: glm-5.1
#       api_key: ""
#       base_url: ""
#       allowed_for: [L0,L1,L2,L3,L4,L5]
#     - name: secondary
#       model: gpt-4o
#       api_key: ""
#       base_url: https://api.openai.com/v1
#       allowed_for: [L0,L1,L2,L3]

policy:
  approval_timeout: 300         # 审批超时秒数
  token_budget: 1000000         # 单 Goal Token 上限
  token_warning: 0.8            # 预算警告阈值
  auto_fix_max: 3               # 自修正最大次数
  flow_degrade_threshold: 3     # Flow 降级触发次数
  goal_anchor_interval: 20      # GoalAnchor 间隔
  recovery_retry_max: 3         # Recovery 重试最大次数

persona: concise                 # concise|warm|minimal
